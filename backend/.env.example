# ========================================
# Backend Environment Configuration Template
# ========================================

# Copy this to .env.development or .env.production
# IMPORTANT: Never commit real secrets - use environment variables in deployment

# Network Configuration
LOCAL_IP=192.168.1.33
PORT=3001

# Blockchain
ETHEREUM_RPC_URL=http://127.0.0.1:8545
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
SEPOLIA_CONTRACT_ADDRESS=0x80c410CFb20c85eFFeA6469Bb1e4703955cF4D48
# PLATFORM_PRIVATE_KEY=generate_your_own_key

# DID Registry
DID_REGISTRY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
# GAS_STATION_PRIVATE_KEY=generate_your_own_key

# Security - MUST be changed for any shared/deployed environment
# JWT_SECRET must be at least 64 characters for security
JWT_SECRET=generate-a-secure-64-char-minimum-secret-key-for-production-use
COMPANY_DID=did:ethr:0x70997970C51812dc3A010C7d01b50e0d17dc79C8

# Admin Authentication
# Generate secure tokens (minimum 32 characters) - do NOT use default values
# ADMIN_TOKEN=your-secure-admin-token-min-32-chars
# ADMIN_TOKENS=token1-min-32-chars,token2-min-32-chars
# Set to 'false' to disable static token authentication and require JWT only
# ADMIN_ALLOW_STATIC_TOKENS=false

# Environment
NODE_ENV=development
# DEMO_MODE - Signature verification is ALWAYS enforced regardless of this setting
DEMO_MODE=false

# Challenge Storage (R8)
# Set CHALLENGE_STORAGE_TYPE=redis in staging/production to enable durable challenge storage.
# If REDIS_URL is missing or Redis is unreachable, backend automatically falls back to in-memory mode.
CHALLENGE_STORAGE_TYPE=memory
REDIS_URL=redis://localhost:6379
