{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API server for Decentralized Trust Platform",
  "main": "dist/app.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development TS_NODE_FILES=true nodemon src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest",
    "test:verifier-profiles": "node scripts/test-verifier-profiles-flow.js",
    "test:verifier-profiles-negative": "node scripts/test-verifier-profiles-negative.js",
    "test:selective-disclosure": "node scripts/test-selective-disclosure-flow.js",
    "test:selective-disclosure-negative": "node scripts/test-selective-disclosure-negative.js",
    "test:identity-proof-misuse": "node scripts/test-identity-proof-misuse.js",
    "test:auth-timeline": "node scripts/test-auth-timeline.js",
    "test:enterprise-e2e": "node scripts/test-enterprise-e2e-flow.js",
    "test:full-e2e": "node scripts/test-full-e2e-flow.js",
    "clean": "rimraf dist",
    "blockchain:setup": "node scripts/setup-blockchain.js",
    "blockchain:deploy": "cd ../contracts && npx hardhat run scripts/deploy-sepolia.js --network sepolia",
    "blockchain:test": "cd ../contracts && npx hardhat test",
    "sepolia:status": "node scripts/sepolia-status.js",
    "wallet:generate": "node scripts/generate-wallet.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "decentralized-trust-platform": "file:..",
    "did-jwt": "^7.4.7",
    "dotenv": "^16.3.1",
    "ethers": "^6.0.0",
    "ethr-did": "^2.3.9",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.2",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "snarkjs": "^0.7.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@openzeppelin/contracts": "^5.4.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.4",
    "@types/node": "^20.4.5",
    "@types/snarkjs": "^0.7.9",
    "@types/uuid": "^9.0.3",
    "cross-env": "^10.0.0",
    "hardhat": "^3.0.6",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "rimraf": "^5.0.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "keywords": [
    "DID",
    "blockchain",
    "authentication",
    "API"
  ],
  "author": "DecentralizedTrustPlatform Team",
  "license": "MIT"
}
