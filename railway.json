{
  "name": "Decentralized Trust Platform",
  "services": [
    {
      "name": "backend",
      "source": {
        "type": "directory",
        "directory": "./backend"
      },
      "variables": {
        "NODE_ENV": "production",
        "DEMO_MODE": "false",
        "ETHEREUM_RPC_URL": "${{ETHEREUM_RPC_URL}}",
        "CONTRACT_ADDRESS": "0x80c410CFb20c85eFFeA6469Bb1e4703955cF4D48",
        "JWT_SECRET": "${{JWT_SECRET}}",
        "GAS_STATION_PRIVATE_KEY": "${{GAS_STATION_PRIVATE_KEY}}"
      },
      "build": {
        "command": "npm run build"
      },
      "start": {
        "command": "npm start"
      },
      "healthcheck": {
        "path": "/api/health",
        "timeout": 10
      }
    },
    {
      "name": "portal",
      "source": {
        "type": "directory", 
        "directory": "./portal"
      },
      "variables": {
        "NODE_ENV": "production",
        "VITE_DEMO_MODE": "true",
        "VITE_CONTRACT_ADDRESS": "0x80c410CFb20c85eFFeA6469Bb1e4703955cF4D48"
      },
      "build": {
        "command": "npm run build"
      },
      "start": {
        "command": "nginx -g 'daemon off;'"
      },
      "healthcheck": {
        "path": "/health",
        "timeout": 10
      }
    }
  ]
}